---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ResourceList from '../components/ResourceList.astro';

const resources = (
  await getCollection(
    'resources',
    ({ data }) => data.public && data.category === 'Leaders',
  )
).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<Layout
  title="Leader Resources"
  description="Planning and communication resources for Pack 60 adult volunteers."
>
  <header class="page-header">
    <div class="prose">
      <Breadcrumbs
        items={[{ href: '/leader-resources/', label: 'Leader Resources' }]}
      />
      <p class="eyebrow">For volunteers</p>
      <h1>Leader Resources</h1>
      <p class="lead">
        Guidance for planning den meetings, pack events, communications, and
        website content.
      </p>
    </div>
  </header>
  <section class="content-band">
    <div class="container">
      <article class="prose">
        <h2>Leader planning basics</h2>
        <ul>
          <li>
            Plan meetings with age-appropriate activities and clear adult
            support.
          </li>
          <li>
            Use official training and program resources from Scouting America.
          </li>
          <li>
            Keep pack communications clear, timely, and useful for families.
          </li>
          <li>Review photo guidance before posting event images.</li>
        </ul>
        <h2>Public leader resources</h2>
        <ResourceList
          items={resources.map((resource) => ({
            title: resource.data.title,
            description: resource.data.description,
            href: `/resources/${resource.slug}/`,
          }))}
        />
      </article>
    </div>
  </section>
</Layout>
