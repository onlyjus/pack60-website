---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

export async function getStaticPaths() {
  const dens = await getCollection('dens', ({ data }) => data.public);
  return dens.map((den) => ({
    params: { slug: den.slug },
    props: { den },
  }));
}

const { den } = Astro.props;
const { Content } = await den.render();
---

<Layout title={`${den.data.title} Den`} description={den.data.description}>
  <header class="page-header">
    <div class="prose">
      <Breadcrumbs
        items={[
          { href: '/dens/', label: 'Dens' },
          { href: `/dens/${den.slug}/`, label: den.data.title },
        ]}
      />
      <p class="eyebrow">{den.data.grade}</p>
      <h1>{den.data.title}</h1>
      <p class="lead">{den.data.description}</p>
    </div>
  </header>
  <article class="content-band prose">
    <Content />
  </article>
</Layout>
