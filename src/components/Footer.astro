---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h2>Cub Scout Pack 60</h2>
      <p>
        Cub Scout Pack 60 is a local Scouting America unit serving families in
        the Morgantown, WV area. This site is maintained by pack volunteers.
      </p>
      <p class="small">
        © {year} Cub Scout Pack 60. This site is maintained by pack volunteers.
      </p>
    </div>
    <nav aria-label="Footer navigation">
      <a href="/join/">Join Pack 60</a>
      <a href="/contact/">Contact the pack</a>
      <a href="/privacy/">Privacy / Public Content Policy</a>
      <a href="/resources/">Resources</a>
      <a href="https://paypal.me/cubscoutpack60wv">Donate / Pay Activity Fees</a
      >
      <a href="https://advancements.scouting.org/">Scoutbook Plus</a>
      <a href="https://mountaineerscouting.org/">Mountaineer Area Council</a>
    </nav>
    <address>
      <strong>General location</strong>
      <span>Morgantown, WV area</span>
      <a href="mailto:info@pack60.org">info@pack60.org</a>
      <a href="mailto:membership@pack60.org">membership@pack60.org</a>
    </address>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.16);
    background: var(--color-green);
    color: #fff;
    padding: 3rem 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(180px, 0.6fr) minmax(
        180px,
        0.6fr
      );
    gap: 2rem;
  }

  h2 {
    margin: 0 0 0.6rem;
    font-size: 1.35rem;
  }

  p {
    max-width: 60ch;
    margin: 0 0 1rem;
    color: rgba(255, 255, 255, 0.86);
  }

  .small {
    font-size: 0.9rem;
  }

  nav,
  address {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
    font-style: normal;
  }

  a {
    color: #fff4bf;
  }

  a:hover {
    color: #fff;
  }

  span {
    color: rgba(255, 255, 255, 0.86);
  }

  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
