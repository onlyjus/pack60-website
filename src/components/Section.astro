---
interface Props {
  eyebrow?: string;
  title?: string;
  intro?: string;
  variant?: 'default' | 'alt';
}

const { eyebrow, title, intro, variant = 'default' } = Astro.props;
---

<section class:list={['section', variant]}>
  <div class="container">
    {
      (eyebrow || title || intro) && (
        <header class="section-header">
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          {title && <h2>{title}</h2>}
          {intro && <p>{intro}</p>}
        </header>
      )
    }
    <slot />
  </div>
</section>

<style>
  .section {
    padding: 4rem 0;
  }

  .alt {
    background: var(--color-surface-alt);
  }

  .section-header {
    max-width: 760px;
    margin-bottom: 1.5rem;
  }

  .section-header h2 {
    margin: 0;
    color: var(--color-green);
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    line-height: 1.12;
  }

  .section-header p:not(.eyebrow) {
    margin: 0.75rem 0 0;
    color: var(--color-muted);
    font-size: 1.08rem;
  }

  @media (max-width: 700px) {
    .section {
      padding: 3rem 0;
    }
  }
</style>
