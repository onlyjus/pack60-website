---
interface Props {
  title: string;
  roleType: string;
  timeCommitment: string;
  description: string;
}

const { title, roleType, timeCommitment, description } = Astro.props;
---

<article class="role-card">
  <p>{roleType}</p>
  <h2>{title}</h2>
  <span>{description}</span>
  <small>Time commitment: {timeCommitment}</small>
  <slot />
</article>

<style>
  .role-card {
    height: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: #fff;
    padding: 1rem;
  }

  p {
    margin: 0 0 0.25rem;
    color: var(--color-gold-dark);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0 0 0.35rem;
    color: var(--color-green);
    font-size: 1.15rem;
    line-height: 1.25;
  }

  span,
  small {
    display: block;
    color: var(--color-muted);
  }

  small {
    margin-top: 0.75rem;
    font-weight: 700;
  }
</style>
