---
interface Props {
  title: string;
  grade: string;
  description: string;
  href: string;
}

const { title, grade, description, href } = Astro.props;
---

<article class="den-card">
  <p>{grade}</p>
  <h2><a href={href}>{title}</a></h2>
  <span>{description}</span>
</article>

<style>
  .den-card {
    height: 100%;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: #fff;
    box-shadow: 0 10px 30px rgba(18, 60, 47, 0.06);
    padding: 1rem;
  }

  p {
    margin: 0 0 0.25rem;
    color: var(--color-gold-dark);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0 0 0.35rem;
    color: var(--color-green);
    font-size: 1.18rem;
    line-height: 1.25;
  }

  h2 a {
    color: inherit;
    text-decoration: none;
  }

  h2 a:hover {
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  span {
    color: var(--color-muted);
  }
</style>
