---
import CTAButton from './CTAButton.astro';

interface Props {
  eyebrow?: string;
  title: string;
  description: string;
  primaryHref?: string;
  primaryLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  eyebrow,
  title,
  description,
  primaryHref,
  primaryLabel,
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h1>{title}</h1>
      <p>{description}</p>
      <div class="hero-actions">
        {
          primaryHref && primaryLabel && (
            <CTAButton href={primaryHref}>{primaryLabel}</CTAButton>
          )
        }
        {
          secondaryHref && secondaryLabel && (
            <CTAButton href={secondaryHref} variant="ghost">
              {secondaryLabel}
            </CTAButton>
          )
        }
      </div>
    </div>
    <div
      class="hero-art"
      aria-label="Public-safe Cub Scout activity illustration"
    >
      <img
        src="/images/placeholders/pack-adventure.svg"
        alt="Illustration of camping gear, trail signs, and pinewood derby cars"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      linear-gradient(135deg, rgba(18, 60, 47, 0.94), rgba(31, 79, 120, 0.92)),
      var(--color-green);
    color: #fff;
    padding: clamp(4rem, 9vw, 7rem) 0;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.7fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .hero-copy h1 {
    max-width: 11ch;
    margin: 0;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.96;
  }

  .hero-copy p:not(.eyebrow) {
    max-width: 58ch;
    margin: 1.2rem 0 0;
    color: rgba(255, 255, 255, 0.9);
    font-size: clamp(1.12rem, 3vw, 1.45rem);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.8rem;
  }

  .hero-art {
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.08);
    padding: 1rem;
  }

  .hero-art img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy h1 {
      max-width: 12ch;
    }
  }
</style>
