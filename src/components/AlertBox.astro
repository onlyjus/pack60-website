---
interface Props {
  title?: string;
  tone?: 'info' | 'warning';
}

const { title, tone = 'info' } = Astro.props;
---

<aside class:list={['alert-box', tone]}>
  {title && <h2>{title}</h2>}
  <slot />
</aside>

<style>
  .alert-box {
    border-left: 5px solid var(--color-blue);
    border-radius: var(--radius);
    background: #eef6fb;
    padding: 1rem 1.15rem;
  }

  .warning {
    border-left-color: var(--color-gold-dark);
    background: #fff8df;
  }

  h2 {
    margin: 0 0 0.35rem;
    color: var(--color-green);
    font-size: 1.08rem;
  }

  .alert-box :global(p) {
    margin: 0;
    color: var(--color-muted);
  }
</style>
